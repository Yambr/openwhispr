{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": ["@playwright/test", "@cucumber/cucumber", "node"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", ".playwright-bdd", "reports"]
}
