# OpenWhispr E2E test environment.
# Copy to .env.e2e and edit. The .env.e2e file is gitignored.

# Where the Electron app and HTTP-level scenarios should point. Default matches
# the slim-core docker-compose stack from ../openwhispr-server (api on host :4000).
OPENWHISPR_E2E_BACKEND_URL=http://localhost:4000

# Optional. Auto-generated if unset. Use a stable value if you want to inspect
# leftover test tenants in the dev DB between runs.
# OPENWHISPR_E2E_RUN_ID=local-dev

# Optional. Gate scenarios that mint third-party realtime tokens. Set to true
# only when the server's .env has the corresponding upstream API keys set
# (ASSEMBLYAI_API_KEY / DEEPGRAM_API_KEY).
OPENWHISPR_E2E_ASSEMBLYAI_AVAILABLE=false
OPENWHISPR_E2E_DEEPGRAM_AVAILABLE=false
