#!/usr/bin/env bash
# v1.7.13 pre-push guard: refuse to push without a fresh e2e summary.
#
# Background: v1.7.10 / v1.7.11 / v1.7.13 each shipped a release-breaking
# regression that landed on origin/main without anyone running e2e first.
# Vitest mocks went green, gates went green, prod went red. This hook
# closes the loop by demanding `npm run e2e:checkpoint` before every push.
#
# What this hook checks:
#   1. .planning/e2e-checkpoints/HEAD-<short-sha>.json exists.
#   2. The file references the current HEAD sha (no stale checkpoints).
#   3. The recorded run had passed > 0 AND failed == 0.
#   4. The recorded run is no older than 24h.
#
# Escape hatch (use only in genuine emergencies, documented in commit):
#   git push --no-verify
# Pushing with --no-verify will be visible in `git log` and code review.

set -euo pipefail

# Skip the check when no commits will actually be pushed (e.g., a noop
# `git push --tags` for an already-pushed tag). The hook is invoked with
# refs on stdin; if every line says we're pushing zero (all-zeros sha),
# we have nothing to validate.
have_real_push=0
while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$local_sha" != "0000000000000000000000000000000000000000" ]]; then
    have_real_push=1
  fi
done
if [[ "$have_real_push" -eq 0 ]]; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
head_sha="$(git rev-parse --short=12 HEAD)"
checkpoint="$repo_root/.planning/e2e-checkpoints/HEAD-$head_sha.json"

if [[ ! -f "$checkpoint" ]]; then
  cat <<EOF >&2

╔════════════════════════════════════════════════════════════════════╗
║  PUSH BLOCKED — no e2e checkpoint for HEAD $head_sha          ║
╠════════════════════════════════════════════════════════════════════╣
║                                                                    ║
║  Run e2e first:                                                    ║
║                                                                    ║
║      npm run e2e:checkpoint                                        ║
║                                                                    ║
║  This runs the e2e suite and records pass/fail counts against the  ║
║  current commit. The pre-push hook reads that record.              ║
║                                                                    ║
║  Genuine emergency? Use:                                           ║
║                                                                    ║
║      git push --no-verify                                          ║
║                                                                    ║
║  --no-verify pushes are visible in code review and require a       ║
║  justification in the commit message.                              ║
║                                                                    ║
╚════════════════════════════════════════════════════════════════════╝

EOF
  exit 1
fi

# Read the recorded summary. node is required (already a project dep).
node - "$checkpoint" "$head_sha" <<'NODE'
const fs = require("node:fs");
const [, , file, expectedSha] = process.argv;
const data = JSON.parse(fs.readFileSync(file, "utf8"));
const failures = [];
if (data.sha !== expectedSha) {
  failures.push(`checkpoint SHA mismatch (file=${data.sha}, HEAD=${expectedSha})`);
}
if (typeof data.passed !== "number" || data.passed <= 0) {
  failures.push(`no passed tests recorded (passed=${data.passed})`);
}
if (typeof data.failed !== "number" || data.failed > 0) {
  failures.push(`failures recorded (failed=${data.failed})`);
}
const ageMs = Date.now() - new Date(data.recordedAt).getTime();
const ageH = ageMs / 3_600_000;
if (!Number.isFinite(ageH) || ageH > 24) {
  failures.push(`checkpoint too old (age=${ageH.toFixed(1)}h, max=24h)`);
}
if (failures.length > 0) {
  console.error(`\nPUSH BLOCKED — e2e checkpoint for ${expectedSha} is not green:`);
  for (const f of failures) console.error(`  - ${f}`);
  console.error(`\nRe-run:  npm run e2e:checkpoint\n`);
  process.exit(1);
}
const summary =
  `e2e checkpoint OK — ${data.passed} passed, 0 failed, ` +
  `recorded ${ageH.toFixed(1)}h ago against ${expectedSha}`;
console.log(summary);
NODE
